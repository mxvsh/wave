---
import { ArrowDownToLine, ArrowUpRight, Check } from "@lucide/astro";
import { site } from "../../data/site";
---

<section class="relative z-10 px-6 py-24" id="download">
  <div class="mx-auto max-w-5xl">
    <div class="reveal glass relative overflow-hidden rounded-3xl px-8 py-20 text-center">
      <div
        class="pointer-events-none absolute left-1/2 top-[-8rem] h-[480px] w-[480px] -translate-x-1/2 rounded-full bg-[color:rgba(123,110,246,0.10)] blur-[80px]"
      ></div>
      <div
        class="pointer-events-none absolute inset-0 rounded-3xl bg-gradient-to-br from-[rgba(123,110,246,0.05)] to-transparent"
      ></div>

      <h2 class="relative mb-4 text-[clamp(28px,4vw,44px)] font-bold leading-[1.15] tracking-[-0.025em]">
        Start speaking your mind
      </h2>
      <p class="relative mx-auto mb-10 max-w-[420px] text-[17px] leading-relaxed text-slate-400">
        Download Wave free. Works on macOS 14+. No account needed.
      </p>

      <div class="relative mb-6 flex flex-wrap items-center justify-center gap-3">
        <a
          href={site.ctaPrimary.href}
          class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-accent)] px-7 py-3.5 text-[15px] font-semibold text-white shadow-accent-glow transition-all duration-150 hover:-translate-y-0.5 hover:shadow-accent-glow-lg active:scale-[0.97] no-underline"
        >
          <ArrowDownToLine size={18} stroke-width={2.2} aria-hidden="true" />
          {site.ctaPrimary.label}
        </a>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noreferrer"
          class="glass-md inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-[15px] font-medium text-white transition-all duration-150 hover:-translate-y-0.5 hover:bg-white/10 active:scale-[0.97] no-underline"
        >
          <ArrowUpRight size={17} stroke-width={2.2} aria-hidden="true" />
          View Source
        </a>
      </div>

      <div class="relative flex flex-wrap items-center justify-center gap-5 text-[13px] text-slate-600">
        <span class="flex items-center gap-1.5"><Check size={13} stroke-width={2.5} aria-hidden="true" /> Free &amp; open source</span>
        <span class="flex items-center gap-1.5"><Check size={13} stroke-width={2.5} aria-hidden="true" /> macOS 14 Sonoma or later</span>
        <span class="flex items-center gap-1.5"><Check size={13} stroke-width={2.5} aria-hidden="true" /> Apple Silicon + Intel</span>
      </div>
    </div>
  </div>
</section>
