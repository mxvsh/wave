---
import { CircleHelp } from "@lucide/astro";
import SectionHeading from "../SectionHeading.astro";

const faqs = [
  {
    question: "Is Wave itself paid?",
    answer:
      "No. Wave is 100% free and open source. You can run it locally on your Mac without paying for the app.",
  },
  {
    question: "When do I pay for Groq?",
    answer:
      "Only when you choose Groq for hosted transcription or AI rewrite features. Local Whisper usage stays free on your machine.",
  },
  {
    question: "Can I use Wave fully offline?",
    answer:
      "Yes for local dictation with Whisper. Internet is only needed if you switch to Groq-hosted speech or LLM features.",
  },
  {
    question: "Do I need an account to use Wave?",
    answer:
      "No account is required for the app itself. If you want Groq-hosted features, you use your own Groq API key.",
  },
] as const;
---

<section class="relative z-10 px-6 py-24" id="faq">
  <div class="mx-auto max-w-5xl">
    <SectionHeading
      eyebrow="FAQ"
      title="Common questions, answered"
      description="The basics on pricing, privacy, and how local versus hosted usage works."
    />

    <div class="mt-12 grid gap-4">
      {faqs.map((item, index) => (
        <details
          class:list={[
            "reveal faq-item glass group rounded-2xl p-6",
            index > 0 && "delay-1",
          ]}
        >
          <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
            <span class="text-[16px] font-semibold text-white">{item.question}</span>
            <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-white/6 text-slate-400 transition-colors group-open:text-[var(--color-accent)]">
              <CircleHelp size={18} aria-hidden="true" />
            </span>
          </summary>
          <p class="pt-4 text-[14px] leading-relaxed text-slate-400">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
