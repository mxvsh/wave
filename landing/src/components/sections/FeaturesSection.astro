---
import { Clock3, FileText, Lock, Mic, SendHorizontal, WandSparkles, WifiOff, Zap } from "@lucide/astro";
import SectionHeading from "../SectionHeading.astro";

const features = [
  {
    title: "One-key activation",
    description:
      "Hold Right Option, speak, and release. That is the entire interaction.",
    color: "bg-[color:rgba(123,110,246,0.15)]",
    iconColor: "#7B6EF6",
    delay: "",
    icon: "mic",
  },
  {
    title: "Completely private",
    description:
      "Whisper runs on-device, so your voice stays local with no cloud processing.",
    color: "bg-[color:rgba(52,211,153,0.15)]",
    iconColor: "#34D399",
    delay: "delay-1",
    icon: "lock",
  },
  {
    title: "AI writes from intent",
    description:
      "Speak the intent and Wave turns it into polished text ready to send.",
    color: "bg-[color:rgba(79,142,247,0.15)]",
    iconColor: "#4F8EF7",
    delay: "delay-2",
    icon: "wand",
  },
  {
    title: "Groq for speed",
    description:
      "Switch to Groq for faster transcription when you want minimal latency.",
    color: "bg-[color:rgba(251,146,60,0.15)]",
    iconColor: "#FB923C",
    delay: "delay-1",
    icon: "bolt",
  },
  {
    title: "Works offline",
    description:
      "No Wi-Fi needed. Whisper runs locally, so dictation still works offline.",
    color: "bg-[color:rgba(45,212,191,0.15)]",
    iconColor: "#2DD4BF",
    delay: "delay-2",
    icon: "wifi",
  },
  {
    title: "Streams to your cursor",
    description:
      "Wave inserts text at your cursor directly, with no extra paste step.",
    color: "bg-[color:rgba(236,72,153,0.15)]",
    iconColor: "#EC4899",
    delay: "delay-3",
    icon: "send",
  },
] as const;
---

<section class="relative z-10 px-6 py-24" id="features">
  <div class="mx-auto max-w-5xl">
    <SectionHeading
      eyebrow="Features"
      title="Built to stay out of your way"
      description="Every detail designed for one thing: getting your words out fast, naturally, and privately."
    />

    <div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div
          class:list={[
            "reveal glass group cursor-default rounded-2xl p-7 transition-all duration-200 hover:-translate-y-1 hover:border-white/14 hover:bg-white/6 hover:shadow-card",
            feature.delay,
          ]}
        >
          <div class:list={["mb-5 flex h-11 w-11 items-center justify-center rounded-xl", feature.color]}>
            {feature.icon === "mic" && <Mic size={20} color={feature.iconColor} aria-hidden="true" />}
            {feature.icon === "lock" && <Lock size={20} color={feature.iconColor} aria-hidden="true" />}
            {feature.icon === "wand" && <WandSparkles size={20} color={feature.iconColor} aria-hidden="true" />}
            {feature.icon === "bolt" && <Zap size={20} color={feature.iconColor} aria-hidden="true" />}
            {feature.icon === "wifi" && <WifiOff size={20} color={feature.iconColor} aria-hidden="true" />}
            {feature.icon === "send" && <SendHorizontal size={20} color={feature.iconColor} aria-hidden="true" />}
          </div>
          <h3 class="mb-2 text-[15px] font-semibold">{feature.title}</h3>
          <p class="text-[14px] leading-relaxed text-slate-400">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
