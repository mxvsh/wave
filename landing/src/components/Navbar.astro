---
import LogoMark from "./LogoMark.astro";
import { site } from "../data/site";
---

<nav
  class="pointer-events-none fixed inset-x-0 top-0 z-50 px-5 pt-5"
  role="navigation"
  aria-label="Main navigation"
>
  <div
    class="nav-pill pointer-events-auto mx-auto flex max-w-3xl items-center justify-between rounded-full py-2 pl-4 pr-2"
  >
    <a
      href="/"
      class="flex shrink-0 items-center gap-2.5 text-[15px] font-semibold text-white no-underline"
      aria-label="Wave home"
    >
      <LogoMark size={26} />
      <span>{site.name}</span>
    </a>

    <ul class="hidden flex-1 list-none items-center justify-center gap-0.5 md:flex">
      {site.navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="rounded-full px-3.5 py-1.5 text-sm font-medium text-slate-400 transition-colors duration-150 hover:bg-white/7 hover:text-white no-underline"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noreferrer"
          class="rounded-full px-3.5 py-1.5 text-sm font-medium text-slate-400 transition-colors duration-150 hover:bg-white/7 hover:text-white no-underline"
        >
          GitHub
        </a>
      </li>
    </ul>

    <div class="flex shrink-0 items-center gap-1">
      <a
        href="#"
        class="hidden rounded-full px-3.5 py-2 text-sm font-medium text-slate-400 transition-colors duration-150 hover:bg-white/7 hover:text-white no-underline sm:block"
      >
        Login
      </a>
      <a
        href={site.downloadUrl}
        class="rounded-full bg-[var(--color-accent)] px-5 py-2 text-sm font-semibold whitespace-nowrap text-white shadow-accent-glow transition-all duration-150 hover:opacity-90 active:scale-95 no-underline"
      >
        Download
      </a>
    </div>
  </div>
</nav>
