---
import { ArrowRight } from "@lucide/astro";

const steps = [
  {
    title: "Hold Right Option",
    description: "Works in any app, on any screen. Wave is already running in the background, no window to open.",
    step: 1,
  },
  {
    title: "Say it out loud",
    description: "Speak in full sentences or rough thoughts. Wave transcribes in real time while you stay focused.",
    step: 2,
  },
  {
    title: "Release to insert",
    description: "Let go of the key and your words appear at the cursor, in whatever app you are in.",
    step: 3,
  },
] as const;
---

<section class="relative z-10 px-6 py-24" id="how-it-works">
  <div class="mx-auto max-w-5xl">

    <!-- Centered heading -->
    <div class="mx-auto mb-16 max-w-xl text-center">
      <p class="reveal mb-3 text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-accent)]">How it works</p>
      <h2 class="reveal delay-1 mb-4 text-[clamp(28px,4vw,44px)] font-bold leading-[1.15] tracking-[-0.025em]">One key. Any app. Every word.</h2>
      <p class="reveal delay-2 text-[17px] leading-relaxed text-slate-400">No launcher to open, no mode to switch. Wave lives in the background until you need it.</p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 items-stretch gap-4 md:grid-cols-3">

      <!-- Step 1: Hold -->
      <div class="reveal delay-2 glass group cursor-default rounded-2xl p-7 transition-all duration-200 hover:-translate-y-1 hover:border-white/14 hover:bg-white/6">
        <div class="mb-8 flex justify-center">
          <div class="hiw-key" aria-hidden="true">
            <span class="hiw-key-symbol">⌥</span>
            <span class="hiw-key-word">option</span>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[rgba(123,110,246,0.15)] text-[10px] font-bold text-[var(--color-accent)]">1</span>
          <div>
            <p class="mb-1.5 text-[15px] font-semibold">{steps[0].title}</p>
            <p class="text-[14px] leading-relaxed text-slate-400">{steps[0].description}</p>
          </div>
        </div>
      </div>

      <!-- Step 2: Speak -->
      <div class="reveal delay-3 glass group cursor-default rounded-2xl p-7 transition-all duration-200 hover:-translate-y-1 hover:border-white/14 hover:bg-white/6">
        <div class="mb-8 flex h-[4.5rem] items-center justify-center">
          <div class="hiw-waveform" aria-hidden="true">
            <span class="hiw-bar" style="--h:30%"></span>
            <span class="hiw-bar" style="--h:60%"></span>
            <span class="hiw-bar" style="--h:88%"></span>
            <span class="hiw-bar" style="--h:50%"></span>
            <span class="hiw-bar" style="--h:100%"></span>
            <span class="hiw-bar" style="--h:72%"></span>
            <span class="hiw-bar" style="--h:90%"></span>
            <span class="hiw-bar" style="--h:44%"></span>
            <span class="hiw-bar" style="--h:65%"></span>
            <span class="hiw-bar" style="--h:82%"></span>
            <span class="hiw-bar" style="--h:38%"></span>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[rgba(123,110,246,0.15)] text-[10px] font-bold text-[var(--color-accent)]">2</span>
          <div>
            <p class="mb-1.5 text-[15px] font-semibold">{steps[1].title}</p>
            <p class="text-[14px] leading-relaxed text-slate-400">{steps[1].description}</p>
          </div>
        </div>
      </div>

      <!-- Step 3: Insert -->
      <div class="reveal delay-4 glass group cursor-default rounded-2xl p-7 transition-all duration-200 hover:-translate-y-1 hover:border-white/14 hover:bg-white/6">
        <div class="mb-8 flex h-[4.5rem] items-center justify-center">
          <div class="hiw-insert rounded-xl border border-white/8 bg-[rgba(255,255,255,0.03)] px-4 py-2.5" aria-hidden="true">
            <span class="text-[13px] text-slate-400">your words appear here</span><span class="hiw-cursor">|</span>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[rgba(123,110,246,0.15)] text-[10px] font-bold text-[var(--color-accent)]">3</span>
          <div>
            <p class="mb-1.5 text-[15px] font-semibold">{steps[2].title}</p>
            <p class="text-[14px] leading-relaxed text-slate-400">{steps[2].description}</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Works in any app strip -->
    <div class="reveal delay-4 mt-6 rounded-2xl border border-white/6 bg-white/[0.02] px-6 py-4">
      <p class="text-center text-[13px] leading-relaxed text-slate-500">
        Works in&nbsp;
        <span class="text-slate-400">Mail &middot; Messages &middot; Slack &middot; Notion &middot; Notes &middot; Linear &middot; Figma &middot; Arc</span>
        &nbsp;&mdash; and anywhere else you can type
      </p>
    </div>

  </div>
</section>

<style>
  /* Key visual */
  .hiw-key {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    width: 5rem;
    height: 5rem;
    border-radius: 16px;
    border: 1px solid rgba(123, 110, 246, 0.45);
    background: linear-gradient(180deg, rgba(20, 22, 28, 0.95), rgba(9, 10, 13, 0.98));
    box-shadow:
      0 0 0 1px rgba(123, 110, 246, 0.1),
      0 0 28px rgba(123, 110, 246, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }
  .hiw-key-symbol {
    font-size: 1.6rem;
    line-height: 1;
    color: #dcd7ff;
  }
  .hiw-key-word {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: lowercase;
    color: rgba(220, 215, 255, 0.55);
  }

  /* Waveform visual */
  .hiw-waveform {
    display: flex;
    align-items: center;
    gap: 3.5px;
    height: 3rem;
  }
  .hiw-bar {
    display: block;
    width: 3px;
    height: var(--h);
    border-radius: 2px;
    background: linear-gradient(180deg, rgba(123, 110, 246, 0.9), rgba(79, 142, 247, 0.55));
    animation: hiwBarPulse 2.2s ease-in-out infinite alternate;
  }
  .hiw-bar:nth-child(2) { animation-delay: 0.2s; }
  .hiw-bar:nth-child(3) { animation-delay: 0.4s; }
  .hiw-bar:nth-child(4) { animation-delay: 0.15s; }
  .hiw-bar:nth-child(5) { animation-delay: 0.55s; }
  .hiw-bar:nth-child(6) { animation-delay: 0.3s; }
  .hiw-bar:nth-child(7) { animation-delay: 0.45s; }
  .hiw-bar:nth-child(8) { animation-delay: 0.1s; }
  .hiw-bar:nth-child(9) { animation-delay: 0.35s; }
  .hiw-bar:nth-child(10) { animation-delay: 0.5s; }
  .hiw-bar:nth-child(11) { animation-delay: 0.25s; }
  @keyframes hiwBarPulse {
    from { opacity: 0.4; transform: scaleY(0.75); }
    to   { opacity: 1;   transform: scaleY(1); }
  }

  /* Cursor visual */
  .hiw-cursor {
    display: inline-block;
    margin-left: 2px;
    color: var(--color-accent);
    font-weight: 300;
    animation: hiwCursorBlink 1.1s step-end infinite;
  }
  @keyframes hiwCursorBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hiw-bar { animation: none; opacity: 0.7; }
    .hiw-cursor { animation: none; }
  }
</style>
