---
import { site } from "../../data/site";
---

<section class="relative z-10 px-6 py-24" id="download">
  <div class="mx-auto max-w-5xl">
    <div class="reveal glass relative overflow-hidden rounded-3xl px-8 py-20 text-center">
      <div
        class="pointer-events-none absolute left-1/2 top-[-8rem] h-[480px] w-[480px] -translate-x-1/2 rounded-full bg-[color:rgba(123,110,246,0.10)] blur-[80px]"
      ></div>
      <div
        class="pointer-events-none absolute inset-0 rounded-3xl bg-gradient-to-br from-[rgba(123,110,246,0.05)] to-transparent"
      ></div>

      <h2 class="relative mb-4 text-[clamp(28px,4vw,44px)] font-bold leading-[1.15] tracking-[-0.025em]">
        Start speaking your mind
      </h2>
      <p class="relative mx-auto mb-10 max-w-[420px] text-[17px] leading-relaxed text-slate-400">
        Download Wave free. Works on macOS 14+. No account needed.
      </p>

      <div class="relative mb-6 flex flex-wrap items-center justify-center gap-3">
        <a
          href={site.ctaPrimary.href}
          class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-accent)] px-7 py-3.5 text-[15px] font-semibold text-white shadow-accent-glow transition-all duration-150 hover:-translate-y-0.5 hover:shadow-accent-glow-lg active:scale-[0.97] no-underline"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          {site.ctaPrimary.label}
        </a>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noreferrer"
          class="glass-md inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-[15px] font-medium text-white transition-all duration-150 hover:-translate-y-0.5 hover:bg-white/10 active:scale-[0.97] no-underline"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"></path></svg>
          View Source
        </a>
      </div>

      <div class="relative flex flex-wrap items-center justify-center gap-5 text-[13px] text-slate-600">
        <span class="flex items-center gap-1.5"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg> Free &amp; open source</span>
        <span class="flex items-center gap-1.5"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg> macOS 14 Sonoma or later</span>
        <span class="flex items-center gap-1.5"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg> Apple Silicon + Intel</span>
      </div>
    </div>
  </div>
</section>
