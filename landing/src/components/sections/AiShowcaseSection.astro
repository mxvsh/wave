---
import { ArrowRight, Mic, Sparkles, Wand2 } from "@lucide/astro";

const aiExamples = [
  {
    prompt: "Write an email to apply for leave tomorrow, doctor appointment in the morning.",
    output: "Hi Sarah, I'd like to take tomorrow off for a doctor appointment. I'll wrap up anything urgent before I leave today.",
    label: "Leave request",
  },
  {
    prompt: "Reply and say I can join after 3 PM, ask them to send the agenda first.",
    output: "Thanks for the invite — I can join after 3 PM. Could you send the agenda beforehand so I can come prepared?",
    label: "Meeting reply",
  },
  {
    prompt: "Standup update: fixed the sync bug, reviewed landing page, shipping hotkey settings today.",
    output: "Fixed the sync bug, reviewed the landing page changes, and shipping hotkey settings later today.",
    label: "Standup",
  },
  {
    prompt: "What is 18% tip on 94 dollars?",
    output: "$16.92",
    label: "Quick Question",
  },
] as const;
---

<section class="relative z-10 px-6 py-24" id="ai-agent">
  <div class="mx-auto max-w-5xl">

    <!-- Centered heading -->
    <div class="mx-auto mb-14 max-w-xl text-center">
      <p class="reveal mb-3 text-xs font-semibold uppercase tracking-[0.1em] text-[var(--color-accent)]">AI Mode</p>
      <h2 class="reveal delay-1 mb-4 text-[clamp(28px,4vw,44px)] font-bold leading-[1.15] tracking-[-0.025em]">Speak the intent, not the draft</h2>
      <p class="reveal delay-2 text-[17px] leading-relaxed text-slate-400">Instead of dictating every word, just describe what you need. Wave turns it into clean text at your cursor.</p>
    </div>

    <!-- Showcase card -->
    <div
      class="reveal delay-2 ai-showcase relative overflow-hidden rounded-[28px] border border-white/8 shadow-[0_24px_64px_rgba(0,0,0,0.45)]"
      data-ai-examples={JSON.stringify(aiExamples)}
    >
      <!-- Ambient glows -->
      <div class="pointer-events-none absolute -left-24 -top-24 h-72 w-72 rounded-full bg-[rgba(123,110,246,0.09)] blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-20 -right-20 h-72 w-72 rounded-full bg-[rgba(79,142,247,0.07)] blur-3xl"></div>

      <!-- Tab bar -->
      <div class="relative flex flex-wrap items-center gap-2 border-b border-white/6 bg-[rgba(10,11,16,0.9)] px-5 py-3.5">
        <div class="mr-2 flex h-7 w-7 items-center justify-center rounded-lg bg-[rgba(123,110,246,0.15)]">
          <Wand2 size={13} color="#7b6ef6" aria-hidden="true" />
        </div>
        <span class="mr-auto text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-600">AI Mode</span>
        <div class="flex flex-wrap gap-1.5">
          {aiExamples.map((ex, i) => (
            <button
              class:list={["ai-tab rounded-full border px-3 py-1 text-[11px] font-medium transition-all duration-150 cursor-pointer", i === 0 ? "is-active" : ""]}
              data-index={i}
              type="button"
            >
              {ex.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Two-panel body -->
      <div class="grid grid-cols-1 md:grid-cols-2">

        <!-- You say -->
        <div class="border-b border-white/5 bg-[rgba(9,10,14,0.92)] p-8 md:border-b-0 md:border-r">
          <div class="mb-5 flex items-center gap-2.5">
            <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-[rgba(123,110,246,0.14)]">
              <Mic size={14} color="#7b6ef6" aria-hidden="true" />
            </div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">You say</p>
          </div>
          <p class="ai-showcase-prompt min-h-[4.5rem] text-[15px] italic leading-[1.75] text-slate-300">
            &ldquo;{aiExamples[0].prompt}&rdquo;
          </p>
        </div>

        <!-- Wave writes -->
        <div class="relative bg-[rgba(12,13,19,0.98)] p-8">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[rgba(123,110,246,0.2)] to-transparent md:hidden"></div>
          <div class="mb-5 flex items-center gap-2.5">
            <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-[rgba(79,142,247,0.14)]">
              <Sparkles size={14} color="#4f8ef7" aria-hidden="true" />
            </div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">Wave writes</p>
          </div>
          <p class="ai-showcase-output line-clamp-3 min-h-[4.5rem] text-[15px] leading-[1.75] text-white">
            {aiExamples[0].output}
          </p>
        </div>
      </div>

      <!-- Footer strip -->
      <div class="flex items-center justify-center gap-6 border-t border-white/5 bg-[rgba(9,10,14,0.8)] px-6 py-3.5">
        <span class="text-[12px] text-slate-600">Works in any text field</span>
        <span class="h-1 w-1 rounded-full bg-white/10"></span>
        <span class="text-[12px] text-slate-600">No editing needed</span>
        <span class="h-1 w-1 rounded-full bg-white/10"></span>
        <span class="text-[12px] text-slate-600">Sounds like you meant it</span>
      </div>
    </div>

  </div>
</section>

<style>
  .ai-tab {
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(148, 163, 184, 1);
  }
  .ai-tab:hover:not(.is-active) {
    background: rgba(255, 255, 255, 0.07);
    color: rgba(226, 232, 240, 1);
  }
  .ai-tab.is-active {
    border-color: rgba(123, 110, 246, 0.35);
    background: rgba(123, 110, 246, 0.15);
    color: #c4bfff;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".ai-showcase").forEach((showcase) => {
    const raw = showcase.getAttribute("data-ai-examples");
    if (!raw) return;

    const examples: { prompt: string; output: string; label: string }[] = JSON.parse(raw);
    if (!examples.length) return;

    const promptEl = showcase.querySelector<HTMLElement>(".ai-showcase-prompt");
    const outputEl = showcase.querySelector<HTMLElement>(".ai-showcase-output");
    const tabs = showcase.querySelectorAll<HTMLElement>(".ai-tab");

    let current = 0;

    const render = (index: number) => {
      const item = examples[index];
      if (promptEl) promptEl.textContent = `\u201C${item.prompt}\u201D`;
      if (outputEl) outputEl.textContent = item.output;
      tabs.forEach((tab, i) => {
        tab.classList.toggle("is-active", i === index);
      });
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => {
        current = i;
        render(current);
        clearInterval(timer);
        timer = window.setInterval(advance, 4200);
      });
    });

    const advance = () => {
      current = (current + 1) % examples.length;
      render(current);
    };

    let timer = window.setInterval(advance, 4200);
  });
</script>
