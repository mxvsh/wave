---
interface Props {
  size?: number;
}

const { size = 28 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 28 28"
  fill="none"
  aria-hidden="true"
>
  <rect width="28" height="28" rx="8" fill="url(#wave-logo-gradient)" />
  <path
    d="M5 14 Q7.5 8 10 14 Q12.5 20 15 14 Q17.5 8 20 14 Q22.5 20 23 14"
    stroke="white"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
  />
  <defs>
    <linearGradient id="wave-logo-gradient" x1="0" y1="0" x2="28" y2="28">
      <stop offset="0%" stop-color="#7b6ef6" />
      <stop offset="100%" stop-color="#4f8ef7" />
    </linearGradient>
  </defs>
</svg>
