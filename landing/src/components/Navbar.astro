---
import { site } from "../data/site";
---

<nav
  class="pointer-events-none fixed inset-x-0 top-0 z-50 px-5 pt-5"
  role="navigation"
  aria-label="Main navigation"
>
  <div
    class="nav-pill pointer-events-auto mx-auto grid max-w-3xl grid-cols-[auto_1fr_auto] items-center rounded-full py-2 pl-4 pr-2"
  >
    <a
      href="/"
      class="flex min-w-[6rem] items-center gap-2.5 text-[15px] font-semibold text-white no-underline"
      aria-label="Wave home"
    >
      <img src="/logo.svg" alt="" class="h-[26px] w-[26px]" />
      <span>{site.name}</span>
    </a>

    <ul class="hidden list-none items-center justify-center gap-0.5 md:flex">
      {site.navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="rounded-full px-3.5 py-1.5 text-sm font-medium text-slate-400 transition-colors duration-150 hover:bg-white/7 hover:text-white no-underline"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noreferrer"
          class="rounded-full px-3.5 py-1.5 text-sm font-medium text-slate-400 transition-colors duration-150 hover:bg-white/7 hover:text-white no-underline"
        >
          GitHub
        </a>
      </li>
    </ul>

    <div class="flex min-w-[6rem] justify-end">
      <button
        type="button"
        data-download-trigger
        class="rounded-full bg-[var(--color-accent)] px-5 py-2 text-sm font-semibold whitespace-nowrap text-white shadow-accent-glow transition-all duration-150 hover:opacity-90 active:scale-95 no-underline"
      >
        Download
      </button>
    </div>
  </div>
</nav>
