---
import { site } from "../../data/site";
---

<section class="relative z-10 px-6 pb-24 pt-40 text-center">
  <div class="mx-auto max-w-4xl">
    <div
      class="glass-md reveal mb-8 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-[13px] font-medium text-slate-400"
    >
      <span
        class="h-[7px] w-[7px] shrink-0 rounded-full bg-emerald-400 shadow-[0_0_8px_#34d399] animate-pulse-dot"
        aria-hidden="true"
      ></span>
      Now with Groq ultra-fast transcription
    </div>

    <h1
      class="reveal delay-1 mb-6 text-[clamp(44px,7vw,78px)] font-bold leading-[1.08] tracking-[-0.03em]"
    >
      The right option
      <br />
      <span class="text-gradient">for your every word</span>
    </h1>

    <p
      class="reveal delay-2 mx-auto mb-11 max-w-[560px] text-[clamp(16px,2.2vw,19px)] leading-relaxed text-slate-400"
    >
      A native macOS dictation app that turns your voice into text instantly.
      Local Whisper for complete privacy or Groq for real-time speed. No
      accounts. No friction.
    </p>

    <div class="reveal delay-3 flex flex-wrap items-center justify-center gap-3">
      <a
        href={site.ctaPrimary.href}
        class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-accent)] px-7 py-3.5 text-[15px] font-semibold text-white shadow-accent-glow transition-all duration-150 hover:-translate-y-0.5 hover:shadow-accent-glow-lg active:scale-[0.97] no-underline"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        {site.ctaPrimary.label}
      </a>
      <a
        href={site.ctaSecondary.href}
        target="_blank"
        rel="noreferrer"
        class="glass-md inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-[15px] font-medium text-white transition-all duration-150 hover:-translate-y-0.5 hover:bg-white/10 active:scale-[0.97] no-underline"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"></path>
        </svg>
        {site.ctaSecondary.label}
      </a>
    </div>

    <p
      class="reveal delay-4 mt-8 flex items-center justify-center gap-2 text-[13px] text-slate-600"
      aria-label="Activate with Right Option key"
    >
      Press <span class="key-cap" aria-hidden="true">⌥</span><span class="key-cap" aria-hidden="true">Right Option</span> anywhere to start dictating
    </p>

    <div class="reveal delay-5 mt-12 flex justify-center">
      <div
        class="inline-flex items-center rounded-full border border-white/10 bg-[#111318] px-4 py-2.5 shadow-[0_2px_20px_rgba(0,0,0,0.5)]"
        role="img"
        aria-label="Audio waveform visualization"
      >
        <canvas
          id="hero-waveform"
          width="140"
          height="28"
          style="width:140px;height:28px;display:block"
        ></canvas>
      </div>
    </div>
  </div>
</section>

<script>
  const canvas = document.getElementById("hero-waveform");
  if (canvas instanceof HTMLCanvasElement) {
    const ctx = canvas.getContext("2d");
    if (ctx) {
      const dpr = window.devicePixelRatio || 1;
      const width = 140;
      const height = 28;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.scale(dpr, dpr);

      let time = 0;
      const drawWave = () => {
        ctx.clearRect(0, 0, width, height);
        const bars = 28;
        const barWidth = 2;
        const gap = 2;
        const totalWidth = bars * barWidth + (bars - 1) * gap;
        const startX = (width - totalWidth) / 2;

        for (let i = 0; i < bars; i += 1) {
          const x = startX + i * (barWidth + gap);
          const amplitude =
            Math.abs(Math.sin(i * 0.45 + time * 0.75) * 0.5 +
            Math.sin(i * 0.2 + time * 0.45) * 0.3 +
            Math.sin(i * 0.7 + time * 1.1) * 0.2);
          const barHeight = Math.max(2, amplitude * height * 0.85);
          const y = (height - barHeight) / 2;
          ctx.fillStyle = `rgba(180,175,255,${0.35 + amplitude * 0.65})`;
          ctx.beginPath();
          ctx.roundRect(x, y, barWidth, barHeight, 1);
          ctx.fill();
        }

        time += 0.02;
        requestAnimationFrame(drawWave);
      };

      drawWave();
    }
  }
</script>
